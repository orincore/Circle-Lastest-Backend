# ==============================================
# CIRCLE APP - ENVIRONMENT CONFIGURATION
# ==============================================
# SECURITY WARNING: Never commit this file with real values!
# Keep all secrets secure and rotate them regularly.
# ==============================================

# Server Configuration
PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# GraphQL Configuration
GRAPHQL_INTROSPECTION=false
GRAPHQL_PLAYGROUND=false

# OTA Updates Configuration
INTERNAL_API_KEY=your-internal-api-key-here
OTA_UPDATES_ENABLED=true

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# Service role key (KEEP SECRET! Has admin privileges)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Postgres migration (see docs/superpowers/specs/2026-07-05-supabase-to-postgres-migration-design.md)
SUPABASE_DATABASE_URL=postgresql://postgres.your-project-ref:your_password@your-pooler-host:5432/postgres
DATABASE_URL=postgresql://circle:circle_dev_password@localhost:5433/circle

# Authentication & Security
# CRITICAL: Generate a strong random secret (min 32 characters)
# Use: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MIN_32_CHARS

# Redis Configuration (for caching and rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS S3 Configuration
# Use your existing bucket: media.orincore.com
AWS_REGION=ap-south-1
AWS_S3_BUCKET=media.orincore.com
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
# These same credentials/region are also used to send email via AWS SES --
# see the Email section below.

# Social Media OAuth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google OAuth Configuration
# Get these from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OpenAI (used for AI "About Me" bio generation - gpt-5-nano)
OPENAI_API_KEY=your_openai_api_key_here

# Instagram Basic Display API
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_VERIFY_TOKEN=your_random_verify_token_123
FRONTEND_URL=https://circle.orincore.com

# Email (AWS SES)
# Sent via the AWS credentials above (AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY/
# AWS_REGION) -- no separate email credentials needed. The sending domain
# (notifications.orincore.com) must be a verified SES identity in that same
# region. Sender aliases per notification type live in
# src/server/config/emailSenders.ts (verify@, security@, noreply@, billing@,
# support@, marketing@, careers@), not in env vars.
# Optional: attach every send to an existing SES configuration set for
# bounce/complaint/reputation tracking (leave unset if you don't have one).
SES_CONFIGURATION_SET=

# Defaults
DEFAULT_PROFILE_PHOTO_URL=https://placehold.co/200x200?text=Profile

# Razorpay (web payments) - https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Apple App Store Server API (iOS in-app purchase verification)
# Generate an API key at https://appstoreconnect.apple.com/access/api
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_BUNDLE_ID=

# Google Play billing (Real-Time Developer Notifications topic, for subscription webhooks)
GOOGLE_PLAY_PUBSUB_TOPIC=

# YouTube Data API v3 (jam session search + metadata; https://console.cloud.google.com/apis/credentials)
# Server-side only — never sent to the client. Default quota is 10,000 units/day (search.list = 100 units/call).
YOUTUBE_API_KEY=
