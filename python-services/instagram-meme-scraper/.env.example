# Same Postgres database the Node backend uses.
DATABASE_URL=postgresql://circle:password@localhost:5433/circle

# Same S3 bucket/credentials as the Node backend's S3Service (Circle-Lastest-Backend/src/services/s3Service.ts).
AWS_REGION=us-east-1
AWS_S3_BUCKET=media.orincore.com
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# Comma-separated proxy URLs, e.g. http://user:pass@host:port,http://user:pass@host2:port
# Required in production -- scraping directly from this server's own IP defeats the
# purpose of rotation and will get that IP flagged quickly. Leave empty only for local
# testing against a single throwaway source.
MEME_SCRAPER_PROXIES=

# How often the main loop wakes up to check whether any source is due for scraping.
MEME_SCRAPER_TICK_SECONDS=60

# Jittered delay range (seconds) between scraping two different sources back-to-back.
MEME_SCRAPER_SOURCE_DELAY_MIN_SECONDS=45
MEME_SCRAPER_SOURCE_DELAY_MAX_SECONDS=180

# Jittered delay range (seconds) between downloading individual assets of the same post.
MEME_SCRAPER_ASSET_DELAY_MIN_SECONDS=2
MEME_SCRAPER_ASSET_DELAY_MAX_SECONDS=6

# How many of a profile's most recent posts to check per run (newest-first; stops early
# once an already-ingested shortcode is seen).
MEME_SCRAPER_POSTS_PER_RUN=24

# Consecutive-failure thresholds before a source is auto-disabled and needs admin review.
MEME_SCRAPER_MAX_CONSECUTIVE_FAILURES=5

# Flask health-check port.
PORT=5001
